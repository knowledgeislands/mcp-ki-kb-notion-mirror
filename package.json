{
  "name": "@knowledgeislands/mcp-ki-kb-notion-mirror",
  "description": "MCP that mirrors local Knowledge Base markdown notes to a Notion wiki and records the resulting page URLs back into the notes' frontmatter",
  "version": "1.0.0",
  "author": "kris@kris.me.uk",
  "bin": {
    "mcp-ki-kb-notion-mirror": "dist/mcp-server/index.js",
    "mcp-ki-kb-notion-mirror-publish": "dist/cli/cli.js"
  },
  "bugs": {
    "url": "https://github.com/knowledgeislands/mcp-ki-kb-notion-mirror/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tryfabric/martian": "^1.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "husky": "^9.1.7",
    "knip": "^6.27.0",
    "lint-staged": "^17.0.8",
    "markdownlint-cli2": "^0.23.1",
    "mcporter": "^0.12.3",
    "prettier": "^3.9.5",
    "syncpack": "^15.3.2",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/mcp-server/index.d.ts",
      "import": "./dist/mcp-server/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    },
    "./notion-client": {
      "types": "./dist/main/notion-client/index.d.ts",
      "import": "./dist/main/notion-client/index.js"
    },
    "./notes": {
      "types": "./dist/main/notes/index.d.ts",
      "import": "./dist/main/notes/index.js"
    },
    "./trees": {
      "types": "./dist/main/trees/index.d.ts",
      "import": "./dist/main/trees/index.js"
    },
    "./roots": {
      "types": "./dist/main/roots/index.d.ts",
      "import": "./dist/main/roots/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/knowledgeislands/mcp-ki-kb-notion-mirror#readme",
  "keywords": [
    "anthropic",
    "claude",
    "knowledge-base",
    "mcp",
    "model-context-protocol",
    "notion"
  ],
  "license": "MIT",
  "lint-staged": {
    "*.{ts,js,json,jsonc}": "bunx @biomejs/biome check --write --no-errors-on-unmatched",
    "*.md": [
      "bunx prettier --write",
      "bunx markdownlint-cli2"
    ]
  },
  "main": "dist/mcp-server/index.js",
  "packageManager": "bun@1.3.14",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/knowledgeislands/mcp-ki-kb-notion-mirror.git"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/cli/cli.js",
    "clean": "rm -rf {dist,node_modules}",
    "ki:audit": "bun .ki-meta/bin/aggregate.ts audit",
    "ki:authoring:audit": "bun .ki-meta/skills/ki-authoring/audit.ts .",
    "ki:authoring:conform": "bun .ki-meta/skills/ki-authoring/conform.ts .",
    "ki:conform": "bun .ki-meta/bin/aggregate.ts conform",
    "ki:educate": "bun .ki-meta/bin/aggregate.ts educate",
    "ki:engineering:audit": "bun .ki-meta/skills/ki-engineering/audit.ts .",
    "ki:engineering:conform": "bun .ki-meta/skills/ki-engineering/conform.ts .",
    "ki:generate:client": "mcporter emit-ts hnr-mcp-ki-kb-notion-mirror --mode client --out src/generated/client.ts --types-out src/generated/types.d.ts && printf '// @ts-nocheck\\n' | cat - src/generated/client.ts > /tmp/gen-tmp.ts && mv /tmp/gen-tmp.ts src/generated/client.ts",
    "ki:help": "bun .ki-meta/bin/aggregate.ts help",
    "ki:mcp:audit": "bun .ki-meta/skills/ki-mcp/audit.ts .",
    "ki:mcp:conform": "bun .ki-meta/skills/ki-mcp/conform.ts .",
    "ki:project-roadmap:audit": "bun .ki-meta/skills/ki-project-roadmap/audit.ts .",
    "ki:project-roadmap:conform": "bun .ki-meta/skills/ki-project-roadmap/conform.ts .",
    "ki:repo:audit": "bun .ki-meta/skills/ki-repo/audit.ts .",
    "ki:repo:conform": "bun .ki-meta/skills/ki-repo/conform.ts .",
    "ki:server:mcp:dev": "NODE_ENV=development bun --watch src/mcp-server/index.ts",
    "ki:server:mcp:inspect": "NODE_ENV=development bunx @modelcontextprotocol/inspector bun src/mcp-server/index.ts",
    "ki:server:mcp:start": "bun run build && node dist/mcp-server/index.js",
    "ki:test:smoke": "bun run build && bun scripts/smoke.ts",
    "prepare": "husky",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "type": "module"
}
