{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["src/mcp-server/index.ts!", "src/config/index.ts!", "src/main/*/index.ts!", "scripts/*.ts", "src/cli/cli.ts!"],
  "project": ["src/**/*.ts", "scripts/**/*.ts"],
  "ignore": ["src/generated/**", "scripts/ki/**"],
  "ignoreExportsUsedInFile": true,
  "ignoreBinaries": ["printf", "keys"]
}
